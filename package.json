{
  "name": "jsimgui-hx",
  "version": "0.1.1",
  "description": "JS-only Dear ImGui bindings for Haxe backed by the assarbergh-hacksaw jsimgui fork",
  "license": "MIT",
  "keywords": [
    "haxe",
    "imgui",
    "dear-imgui",
    "jsimgui",
    "haxelib"
  ],
  "homepage": "https://github.com/miguelblix99/jsimgui-hx#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/miguelblix99/jsimgui-hx.git"
  },
  "bugs": {
    "url": "https://github.com/miguelblix99/jsimgui-hx/issues"
  },
  "main": "index.js",
  "files": [
    "runtime",
    "src",
    "scripts",
    "haxelib.json",
    "README.md",
    "LICENSE",
    "index.js"
  ],
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "scripts": {
    "postinstall": "node ./scripts/install-haxelib.cjs",
    "pack:haxelib": "node ./scripts/package-haxelib.cjs",
    "build": "bun ./tools/build-jsimgui-and-bindings.sh",
    "pack:dry": "npm pack --dry-run",
    "version": "node ./scripts/sync-haxelib-metadata.cjs",
    "reset": "rm -rf ./build ./node_modules && bun install"
  }
}
